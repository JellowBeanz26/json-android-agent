# Copy this file to ".env" (same folder) and paste your real key below.
# .env is gitignored, so your secret is never committed to GitHub.
#
# Get a key at https://aistudio.google.com  (use your credit-backed project for paid models)
GEMINI_API_KEY=your-gemini-api-key-here

# Which model the agent "brain" uses. Flash = fast & cheap; Pro = strongest.
GEMINI_MODEL=gemini-2.5-flash
